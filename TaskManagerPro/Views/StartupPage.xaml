<Page
    x:Class="TaskManagerPro.Views.StartupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:TaskManagerPro.Models">

    <Grid Padding="24,16,24,24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <FontIcon Glyph="&#xE945;" FontSize="24"
                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            <TextBlock Text="Startup Apps" Style="{StaticResource TitleTextBlockStyle}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Click="Refresh_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="Refresh" />
                </StackPanel>
            </Button>
            <TextBlock VerticalAlignment="Center" Opacity="0.7"
                       Text="Programs that start automatically with Windows" />
        </StackPanel>

        <InfoBar x:Name="ErrorBar"
                 Grid.Row="2"
                 Title="Error"
                 Severity="Error"
                 IsOpen="False"
                 IsClosable="True" />

        <ListView x:Name="StartupList" Grid.Row="3" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:StartupItem">
                    <Grid ColumnSpacing="12" Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ToggleSwitch IsOn="{x:Bind Enabled}"
                                      Toggled="Toggle_Toggled"
                                      OnContent=""
                                      OffContent=""
                                      MinWidth="0" />

                        <!-- آیکون برنامه (استخراج‌شده از EXE) -->
                        <Grid Grid.Column="1" Width="24" Height="24" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xECAA;" FontSize="18" Opacity="0.6"
                                      Visibility="{x:Bind FallbackVisibility, Mode=OneWay}" />
                            <Image Source="{x:Bind Icon, Mode=OneWay}" Width="24" Height="24" />
                        </Grid>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{x:Bind Command}"
                                       Opacity="0.6"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <!-- تأثیر تخمینی روی زمان بوت -->
                        <TextBlock Grid.Column="3"
                                   Text="{x:Bind ImpactText}"
                                   VerticalAlignment="Center"
                                   Opacity="0.8"
                                   ToolTipService.ToolTip="Estimated startup impact" />

                        <TextBlock Grid.Column="4"
                                   Text="{x:Bind LocationText}"
                                   VerticalAlignment="Center"
                                   Opacity="0.7" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
