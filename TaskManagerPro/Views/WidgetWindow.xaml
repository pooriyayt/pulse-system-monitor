<Window
    x:Class="TaskManagerPro.Views.WidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TaskManagerPro.Controls">

    <Grid x:Name="Root" Padding="10" RowSpacing="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- نوار بالایی: عنوان + دکمه‌ی بستن (کل نوار قابل درگ است) -->
        <Grid x:Name="DragBar" ColumnSpacing="8" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE9D9;" FontSize="12"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock Text="Pulse" FontSize="11" Opacity="0.8" VerticalAlignment="Center" />
            </StackPanel>
            <Button x:Name="CloseBtn" Grid.Column="1" Padding="4" Background="Transparent"
                    BorderThickness="0" Click="Close_Click" ToolTipService.ToolTip="Hide widget">
                <FontIcon Glyph="&#xE711;" FontSize="10" />
            </Button>
        </Grid>

        <!-- سه گراف کوچک CPU / RAM / GPU -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2">
                <TextBlock x:Name="CpuLabel" Text="CPU" FontSize="11" Opacity="0.8" />
                <controls:LiveGraph x:Name="CpuGraph" Height="52" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock x:Name="RamLabel" Text="RAM" FontSize="11" Opacity="0.8" />
                <controls:LiveGraph x:Name="RamGraph" Height="52" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="2">
                <TextBlock x:Name="GpuLabel" Text="GPU" FontSize="11" Opacity="0.8" />
                <controls:LiveGraph x:Name="GpuGraph" Height="52" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
