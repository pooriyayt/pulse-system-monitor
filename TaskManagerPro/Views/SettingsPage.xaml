<Page
    x:Class="TaskManagerPro.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="16" MaxWidth="700" HorizontalAlignment="Left">

            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE713;" FontSize="24"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock x:Name="PageTitle" Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>

            <!-- تم -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE771;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="AppearanceHeader" Text="Appearance" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="ThemeSubtitle" Text="Choose the app theme" Opacity="0.7" />
                    <RadioButtons x:Name="ThemeRadios" SelectionChanged="Theme_Changed">
                        <RadioButton Content="Dark (Mica)" />
                        <RadioButton Content="Light (Mica)" />
                        <RadioButton Content="Liquid Glass (deep blur + transparency)" />
                        <RadioButton Content="Midnight (deeper dark, Mica Alt)" />
                        <RadioButton Content="Aurora (light glass, Acrylic)" />
                        <RadioButton Content="OLED (pure black, no blur)" />
                        <RadioButton Content="Paper (flat light)" />
                    </RadioButtons>
                </StackPanel>
            </Border>

            <!-- زبان -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE774;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="LangHeader" Text="Language" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <ComboBox x:Name="LangCombo" Width="220" SelectionChanged="Lang_Changed">
                        <ComboBoxItem Content="English" />
                        <ComboBoxItem Content="فارسی (راست‌به‌چپ)" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- رنگ گراف‌ها -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE790;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="AccentHeader" Text="Accent color" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="AccentSubtitle" Text="Used for the whole app (buttons, highlights) and all live graphs" Opacity="0.7" />
                    <StackPanel x:Name="AccentPanel" Orientation="Horizontal" Spacing="10">
                        <Button Tag="#61AFFE" Background="#61AFFE" Width="36" Height="36" CornerRadius="18" Click="Accent_Click" />
                        <Button Tag="#6CCB5F" Background="#6CCB5F" Width="36" Height="36" CornerRadius="18" Click="Accent_Click" />
                        <Button Tag="#B180F0" Background="#B180F0" Width="36" Height="36" CornerRadius="18" Click="Accent_Click" />
                        <Button Tag="#FF9F45" Background="#FF9F45" Width="36" Height="36" CornerRadius="18" Click="Accent_Click" />
                        <Button Tag="#FF6B6B" Background="#FF6B6B" Width="36" Height="36" CornerRadius="18" Click="Accent_Click" />
                        <Button Tag="#4DD8E6" Background="#4DD8E6" Width="36" Height="36" CornerRadius="18" Click="Accent_Click" />
                        <Button Tag="#FF7EB6" Background="#FF7EB6" Width="36" Height="36" CornerRadius="18" Click="Accent_Click" />
                        <Button Tag="#E7C664" Background="#E7C664" Width="36" Height="36" CornerRadius="18" Click="Accent_Click" />
                        <!-- انتخاب هر رنگ دلخواه: چرخ رنگ + کد هگز -->
                        <Button x:Name="AccentCustomBtn" Width="36" Height="36" CornerRadius="18"
                                ToolTipService.ToolTip="Custom color (wheel / hex)">
                            <FontIcon Glyph="&#xEF3C;" FontSize="16" />
                            <Button.Flyout>
                                <Flyout>
                                    <StackPanel Spacing="8">
                                        <ColorPicker x:Name="AccentPicker"
                                                     IsColorSpectrumVisible="True"
                                                     IsColorSliderVisible="True"
                                                     IsColorChannelTextInputVisible="True"
                                                     IsHexInputVisible="True"
                                                     IsAlphaEnabled="False" />
                                        <Button Content="Apply" Style="{StaticResource AccentButtonStyle}"
                                                HorizontalAlignment="Right" Click="AccentCustom_Apply" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                    <ToggleSwitch x:Name="FillToggle"
                                  Header="Fill area under the graph line"
                                  Toggled="Fill_Toggled" />
                </StackPanel>
            </Border>

            <!-- سرعت رفرش -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="RefreshHeader" Text="Refresh rate" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="RefreshLabel" Opacity="0.7" />
                    <Slider x:Name="RefreshSlider"
                            Minimum="500"
                            Maximum="2000"
                            StepFrequency="100"
                            Width="320"
                            HorizontalAlignment="Left"
                            ValueChanged="Refresh_Changed" />
                </StackPanel>
            </Border>

            <!-- پنجره -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8A7;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="WindowHeader" Text="Window" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <ToggleSwitch x:Name="TopToggle"
                                  Header="Always on top (keep this window above all others)"
                                  Toggled="Top_Toggled" />
                </StackPanel>
            </Border>

            <!-- System Tray -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE823;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="TrayHeader" Text="System tray" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <ToggleSwitch x:Name="TrayToggle"
                                  Header="Live usage icon in the system tray — closing or minimizing hides the app to the tray"
                                  Toggled="Tray_Toggled" />
                    <TextBlock x:Name="TrayItemsLabel" Text="Tray items — pick one or more, each gets its own live icon" Opacity="0.7" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox x:Name="TrayCpuCheck" Content="CPU" MinWidth="0" Checked="TrayItems_Changed" Unchecked="TrayItems_Changed" />
                        <CheckBox x:Name="TrayRamCheck" Content="RAM" MinWidth="0" Checked="TrayItems_Changed" Unchecked="TrayItems_Changed" />
                        <CheckBox x:Name="TrayGpuCheck" Content="GPU" MinWidth="0" Checked="TrayItems_Changed" Unchecked="TrayItems_Changed" />
                        <CheckBox x:Name="TrayDiskCheck" Content="Disk" MinWidth="0" Checked="TrayItems_Changed" Unchecked="TrayItems_Changed" />
                        <CheckBox x:Name="TrayDownCheck" Content="Download" MinWidth="0" Checked="TrayItems_Changed" Unchecked="TrayItems_Changed" />
                        <CheckBox x:Name="TrayUpCheck" Content="Upload" MinWidth="0" Checked="TrayItems_Changed" Unchecked="TrayItems_Changed" />
                    </StackPanel>
                    <TextBlock x:Name="TrayAdminNote" Text="Download / Upload speeds need the app to run as administrator" FontSize="12" Opacity="0.5" />
                    <TextBlock x:Name="IconStyleLabel" Text="Icon style" Opacity="0.7" />
                    <ComboBox x:Name="TrayStyleCombo" Width="240" SelectionChanged="TrayStyle_Changed">
                        <ComboBoxItem Content="Colored badge" />
                        <ComboBoxItem Content="Text only (transparent, colored text)" />
                        <ComboBoxItem Content="Mini live graph" />
                    </ComboBox>
                    <TextBlock x:Name="TraySizeLabel" Opacity="0.7" />
                    <Slider x:Name="TraySizeSlider" Minimum="75" Maximum="150" StepFrequency="5" Width="320" HorizontalAlignment="Left" ValueChanged="TraySize_Changed" />
                    <TextBlock x:Name="TrayColorLabel" Text="Tray icon color" Opacity="0.7" />
                    <StackPanel x:Name="TrayColorPanel" Orientation="Horizontal" Spacing="10">
                        <Button Tag="#61AFFE" Background="#61AFFE" Width="28" Height="28" CornerRadius="14" Click="TrayColor_Click" />
                        <Button Tag="#6CCB5F" Background="#6CCB5F" Width="28" Height="28" CornerRadius="14" Click="TrayColor_Click" />
                        <Button Tag="#B180F0" Background="#B180F0" Width="28" Height="28" CornerRadius="14" Click="TrayColor_Click" />
                        <Button Tag="#FF9F45" Background="#FF9F45" Width="28" Height="28" CornerRadius="14" Click="TrayColor_Click" />
                        <Button Tag="#FF6B6B" Background="#FF6B6B" Width="28" Height="28" CornerRadius="14" Click="TrayColor_Click" />
                        <Button Tag="#4DD8E6" Background="#4DD8E6" Width="28" Height="28" CornerRadius="14" Click="TrayColor_Click" />
                        <Button Tag="#FF7EB6" Background="#FF7EB6" Width="28" Height="28" CornerRadius="14" Click="TrayColor_Click" />
                        <Button Tag="#E7C664" Background="#E7C664" Width="28" Height="28" CornerRadius="14" Click="TrayColor_Click" />
                        <Button x:Name="TrayCustomBtn" Width="28" Height="28" CornerRadius="14"
                                ToolTipService.ToolTip="Custom color (wheel / hex)">
                            <FontIcon Glyph="&#xEF3C;" FontSize="12" />
                            <Button.Flyout>
                                <Flyout>
                                    <StackPanel Spacing="8">
                                        <ColorPicker x:Name="TrayPicker"
                                                     IsColorSpectrumVisible="True"
                                                     IsHexInputVisible="True"
                                                     IsAlphaEnabled="False" />
                                        <Button Content="Apply" Style="{StaticResource AccentButtonStyle}"
                                                HorizontalAlignment="Right" Click="TrayCustom_Apply" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>

                    <!-- کاستوم‌سازی جداگانه‌ی هر آیکون Tray (رنگ / استایل / اندازه) -->
                    <TextBlock x:Name="PerIconHeader"
                               Text="Per-icon customization — override color, style and size for each tray icon"
                               Opacity="0.7" Margin="0,8,0,0" />
                    <StackPanel x:Name="TrayPerIconPanel" Spacing="8" />

                    <ToggleSwitch x:Name="HotkeyToggle"
                                  Header="Global hotkey Ctrl + Alt + T to show / hide the window"
                                  Toggled="Hotkey_Toggled" />
                </StackPanel>
            </Border>

            <!-- آلارم مصرف -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xEA8F;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="AlarmHeader" Text="Usage alarms" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <ToggleSwitch x:Name="AlarmToggle"
                                  Header="Windows notification when CPU / RAM / temperature exceeds a limit"
                                  Toggled="Alarm_Toggled" />
                    <TextBlock x:Name="AlarmCpuLabel" Opacity="0.7" />
                    <Slider x:Name="AlarmCpuSlider" Minimum="50" Maximum="100" StepFrequency="5"
                            Width="320" HorizontalAlignment="Left" ValueChanged="AlarmCpu_Changed" />
                    <TextBlock x:Name="AlarmRamLabel" Opacity="0.7" />
                    <Slider x:Name="AlarmRamSlider" Minimum="50" Maximum="100" StepFrequency="5"
                            Width="320" HorizontalAlignment="Left" ValueChanged="AlarmRam_Changed" />
                    <TextBlock x:Name="AlarmTempLabel" Opacity="0.7" />
                    <Slider x:Name="AlarmTempSlider" Minimum="40" Maximum="110" StepFrequency="5"
                            Width="320" HorizontalAlignment="Left" ValueChanged="AlarmTemp_Changed" />
                </StackPanel>
            </Border>

            <!-- ویجت شناور دسکتاپ -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8A9;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="WidgetHeader" Text="Desktop widget" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <ToggleSwitch x:Name="WidgetToggle"
                                  Header="Small always-on-top window with live CPU / RAM / GPU graphs"
                                  Toggled="Widget_Toggled" />
                </StackPanel>
            </Border>

            <!-- صدا -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE767;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="SoundHeader" Text="Sound" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <ToggleSwitch x:Name="SoundToggle"
                                  Header="Play a subtle sound when ending a task"
                                  Toggled="Sound_Toggled" />
                </StackPanel>
            </Border>

            <!-- میانبرهای صفحه‌کلید -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE765;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="KeyboardHeader" Text="Keyboard shortcuts" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="Shortcut1" Text="Ctrl + 1 ... 5 — switch between tabs" Opacity="0.8" />
                    <TextBlock x:Name="Shortcut2" Text="Ctrl + F — focus search (Processes / Services)" Opacity="0.8" />
                    <TextBlock x:Name="Shortcut3" Text="F5 — refresh the current list" Opacity="0.8" />
                    <TextBlock x:Name="Shortcut4" Text="Delete — end the selected process" Opacity="0.8" />
                    <TextBlock x:Name="Shortcut5" Text="Ctrl + Alt + T — show / hide the window from anywhere in Windows" Opacity="0.8" />
                </StackPanel>
            </Border>

            <!-- آپدیت -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE777;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="UpdateHeader" Text="Updates" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="CheckUpdateBtn" Click="CheckUpdate_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                <TextBlock x:Name="CheckUpdateLabel" Text="Check for updates" />
                            </StackPanel>
                        </Button>
                        <ProgressRing x:Name="UpdateRing" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="UpdateStatus" Opacity="0.7" TextWrapping="Wrap" />
                    <ProgressBar x:Name="UpdateProgress" Visibility="Collapsed" Maximum="100" />
                </StackPanel>
            </Border>

            <!-- درباره -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE946;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="AboutHeader" Text="About" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <TextBlock Text="Pulse 1.5 — System Monitor" />
                    <TextBlock x:Name="AboutDesc" Text="A task manager for Windows 11, built with WinUI 3 and .NET 8."
                               Opacity="0.7"
                               TextWrapping="Wrap" />
                    <TextBlock Text="Made by Pouriya Parniyan"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0" />
                    <HyperlinkButton Content="pouriyaparniyan.ir"
                                     NavigateUri="https://pouriyaparniyan.ir"
                                     Padding="0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
