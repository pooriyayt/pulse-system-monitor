<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TaskManagerPro.Views.ProcessesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:TaskManagerPro.Models"
    NavigationCacheMode="Required">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="FindAccel"/>
        <KeyboardAccelerator Key="F5" Invoked="RefreshAccel"/>
        <KeyboardAccelerator Key="Delete" Invoked="DeleteAccel"/>
    </Page.KeyboardAccelerators>

    <Page.Resources>
        <!-- منوی کلیک راست روی هر پردازه -->
        <MenuFlyout x:Name="ProcessMenu">
            <MenuFlyoutItem x:Name="MenuEndTask" Text="End task" Click="EndTask_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE711;"/>
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutSubItem Text="Set priority">
                <MenuFlyoutSubItem.Icon>
                    <FontIcon Glyph="&#xE9E9;"/>
                </MenuFlyoutSubItem.Icon>
                <MenuFlyoutItem Text="Realtime" Tag="realtime" Click="Priority_Click"/>
                <MenuFlyoutItem Text="High" Tag="high" Click="Priority_Click"/>
                <MenuFlyoutItem Text="Above normal" Tag="abovenormal" Click="Priority_Click"/>
                <MenuFlyoutItem Text="Normal" Tag="normal" Click="Priority_Click"/>
                <MenuFlyoutItem Text="Below normal" Tag="belownormal" Click="Priority_Click"/>
                <MenuFlyoutItem Text="Low" Tag="low" Click="Priority_Click"/>
            </MenuFlyoutSubItem>
            <MenuFlyoutSeparator/>
            <MenuFlyoutItem x:Name="MenuSuspend" Text="Suspend" Click="Suspend_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE769;"/>
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutItem x:Name="MenuResume" Text="Resume" Click="Resume_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE768;"/>
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutItem x:Name="MenuEco" Text="Efficiency mode" Click="Efficiency_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE8BE;"/>
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutSeparator/>
            <MenuFlyoutItem x:Name="MenuCopy" Text="Copy details" Click="CopyDetails_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE8C8;"/>
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutSeparator x:Name="MenuLocationSep"/>
            <MenuFlyoutItem x:Name="MenuOpenLocation" Text="Open file location" Click="OpenLocation_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE838;"/>
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="Properties" Click="Properties_Click">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE946;"/>
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
        </MenuFlyout>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="12">
        <!-- ریسپانسیو: در عرض کم دکمه‌های عملیات به ردیف دوم نوار ابزار می‌روند -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideToolbar">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1220"/>
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="NarrowToolbar">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ActionTools.(Grid.Column)" Value="0"/>
                        <Setter Target="ActionTools.(Grid.Row)" Value="1"/>
                        <Setter Target="ActionTools.(Grid.ColumnSpan)" Value="3"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition IsStaggeringEnabled="True"/>
                <RepositionThemeTransition/>
            </TransitionCollection>
        </Grid.ChildrenTransitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- عنوان -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <FontIcon Glyph="&#xE9F5;" FontSize="24" VerticalAlignment="Center"/>
            <TextBlock Text="Processes" Style="{StaticResource TitleTextBlockStyle}"/>
        </StackPanel>

        <!-- هشدار نیاز به دسترسی ادمین برای ستون Network -->
        <InfoBar
            x:Name="AdminBar"
            Grid.Row="1"
            Severity="Warning"
            IsOpen="False"
            Title="Run as administrator"
            Message="Per-process network usage needs administrator rights. Right-click the app and choose 'Run as administrator' to unlock the Network column."/>

        <!-- نوار ابزار — ریسپانسیو: در عرض کم دو ردیفه می‌شود -->
        <Grid x:Name="Toolbar" Grid.Row="2" ColumnSpacing="8" RowSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- گروه جستجو و فیلتر -->
            <StackPanel x:Name="SearchTools" Orientation="Horizontal" Spacing="8">
                <TextBox
                    x:Name="SearchBox"
                    Width="200"
                    PlaceholderText="Search processes  (Ctrl+F)"
                    TextChanged="Search_TextChanged"/>

                <ComboBox x:Name="SortCombo" Width="140" SelectionChanged="Sort_Changed">
                    <ComboBoxItem Content="Sort: CPU"/>
                    <ComboBoxItem Content="Sort: Memory"/>
                    <ComboBoxItem Content="Sort: Disk"/>
                    <ComboBoxItem Content="Sort: Network"/>
                    <ComboBoxItem Content="Sort: GPU"/>
                    <ComboBoxItem Content="Sort: Name"/>
                    <ComboBoxItem Content="Sort: PID"/>
                </ComboBox>

                <!-- فیلتر پیشرفته -->
                <ComboBox x:Name="FilterCombo" Width="160" SelectionChanged="Sort_Changed">
                    <ComboBoxItem Content="Filter: All"/>
                    <ComboBoxItem Content="Filter: Apps only"/>
                    <ComboBoxItem Content="Filter: CPU &gt; 1%"/>
                    <ComboBoxItem Content="Filter: Memory &gt; 100 MB"/>
                    <ComboBoxItem Content="Filter: Active network"/>
                </ComboBox>
            </StackPanel>

            <!-- گروه دکمه‌های عملیات -->
            <StackPanel x:Name="ActionTools" Orientation="Horizontal" Spacing="8" Grid.Column="2">
                <Button Click="Refresh_Click" ToolTipService.ToolTip="Refresh (F5)">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>

                <Button Click="ExportCsv_Click" ToolTipService.ToolTip="Export the process list to a CSV file">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xEDE1;" FontSize="14"/>
                        <TextBlock Text="Export CSV"/>
                    </StackPanel>
                </Button>

                <Button>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE756;" FontSize="14"/>
                        <TextBlock Text="Run new task"/>
                    </StackPanel>
                    <Button.Flyout>
                        <Flyout x:Name="RunFlyout">
                            <StackPanel Spacing="8" Width="260">
                                <TextBlock Text="Open" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBox x:Name="RunInput" PlaceholderText="e.g. notepad, cmd, mspaint"/>
                                <Button Content="Run" HorizontalAlignment="Right" Style="{StaticResource AccentButtonStyle}" Click="RunTask_Click"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!-- دکمه‌ی سریع End task / Restart برای پردازه‌ی انتخاب‌شده -->
                <Button
                    x:Name="EndTaskBtn"
                    IsEnabled="False"
                    Click="EndTask_Click"
                    Background="#C42B1C"
                    Foreground="White"
                    CornerRadius="6"
                    Padding="14,6"
                    ToolTipService.ToolTip="End the selected task (Delete)">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE711;" FontSize="14"/>
                        <TextBlock x:Name="EndTaskLabel" Text="End task" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <InfoBar x:Name="ErrorBar" Grid.Row="3" Severity="Error" IsOpen="False" Title="Error"/>

        <!-- سرستون‌ها -->
        <Grid Grid.Row="4" ColumnSpacing="8" Padding="44,0,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="85"/>
                <ColumnDefinition Width="85"/>
                <ColumnDefinition Width="55"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Name" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
            <TextBlock Grid.Column="1" Text="PID" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="2" Text="CPU" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="3" Text="Memory" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="4" Text="Disk" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="5" Text="Network" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" HorizontalAlignment="Right"/>
            <TextBlock Grid.Column="6" Text="GPU" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" HorizontalAlignment="Right"/>
        </Grid>

        <!-- درخت پردازه‌ها + لودینگ -->
        <Grid Grid.Row="5">
            <TreeView
                x:Name="ProcessTree"
                ItemsSource="{x:Bind Roots}"
                SelectionMode="Single"
                CanDragItems="False"
                CanReorderItems="False"
                AllowDrop="False"
                ItemInvoked="Tree_ItemInvoked">
                <TreeView.ItemTemplate>
                    <DataTemplate x:DataType="models:ProcessNode">
                        <TreeViewItem
                            ItemsSource="{x:Bind Children}"
                            IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                            RightTapped="Row_RightTapped">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Grid Width="18" Height="18" VerticalAlignment="Center">
                                        <FontIcon Glyph="{x:Bind FallbackGlyph, Mode=OneWay}" FontSize="14" Visibility="{x:Bind FallbackVisibility, Mode=OneWay}"/>
                                        <Image Source="{x:Bind Icon, Mode=OneWay}" Width="18" Height="18"/>
                                    </Grid>
                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}" FontWeight="{x:Bind NameWeight, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <!-- برگ سبز Efficiency mode مثل Task Manager ویندوز -->
                                    <FontIcon
                                        Glyph="&#xE8BE;"
                                        FontSize="12"
                                        Foreground="#4CAF50"
                                        VerticalAlignment="Center"
                                        Visibility="{x:Bind EcoVisibility, Mode=OneWay}"
                                        ToolTipService.ToolTip="Efficiency mode"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="{x:Bind PidText, Mode=OneWay}" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.7"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind CpuText, Mode=OneWay}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind MemText, Mode=OneWay}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind DiskText, Mode=OneWay}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="{x:Bind NetText, Mode=OneWay}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="{x:Bind GpuText, Mode=OneWay}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </TreeViewItem>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <!-- لودینگ اولین بارگذاری -->
            <Grid x:Name="LoadingOverlay">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <ProgressRing IsActive="True" Width="48" Height="48"/>
                    <TextBlock Text="Loading processes..." Opacity="0.7" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="6" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
    </Grid>
</Page>
