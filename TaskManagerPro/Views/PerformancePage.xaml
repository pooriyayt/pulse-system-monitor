<Page
    x:Class="TaskManagerPro.Views.PerformancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:TaskManagerPro.Models"
    xmlns:controls="using:TaskManagerPro.Controls">

    <Grid Padding="24,16,24,24" RowSpacing="12">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition IsStaggeringEnabled="True"/>
                <RepositionThemeTransition/>
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="12">
            <FontIcon Glyph="&#xEC4A;" FontSize="24"
                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            <TextBlock x:Name="PerfTitle" Text="Performance" Style="{StaticResource TitleTextBlockStyle}" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <!-- ریسپانسیو: سایدبار در عرض کم باریک می‌شود -->
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup>
                    <VisualState x:Name="WidePerf">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="1000"/>
                        </VisualState.StateTriggers>
                    </VisualState>
                    <VisualState x:Name="NarrowPerf">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="SideCol.Width" Value="190"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SideCol" Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- سایدبار قطعات (مثل Task Manager ویندوز) -->
            <ListView x:Name="SideList"
                      ItemsSource="{x:Bind Items}"
                      SelectionMode="Single"
                      SelectionChanged="SideList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:PerfSidebarItem">
                        <Grid ColumnSpacing="12" Padding="4,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="{x:Bind Glyph}" FontSize="20" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{x:Bind Subtitle, Mode=OneWay}"
                                           Opacity="0.7"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- جزئیات زنده‌ی قطعه‌ی انتخاب‌شده -->
            <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="16">

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon x:Name="DetailIcon" Glyph="&#xE950;" FontSize="28"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <StackPanel>
                            <TextBlock x:Name="DetailTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock x:Name="DetailSubtitle" Opacity="0.7" />
                        </StackPanel>
                    </StackPanel>

                    <Border x:Name="MainCard" Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="8">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="MainGraphLabel" Opacity="0.7" VerticalAlignment="Center" />
                                <!-- گراف تاریخچه‌دار: زنده / ۱۰ دقیقه / ۱ ساعت -->
                                <ComboBox x:Name="HistCombo" Grid.Column="1" Width="170"
                                          SelectionChanged="Hist_Changed">
                                    <ComboBoxItem Content="Live" />
                                    <ComboBoxItem Content="Last 10 minutes" />
                                    <ComboBoxItem Content="Last hour" />
                                </ComboBox>
                            </Grid>
                            <controls:LiveGraph x:Name="MainGraph" Height="180" />
                            <!-- اسکرول به عقب در تاریخچه -->
                            <Grid x:Name="HistScrollRow" Visibility="Collapsed" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="HistSlider" Minimum="0" Maximum="100" Value="100"
                                        ValueChanged="HistSlider_Changed" />
                                <TextBlock x:Name="HistLabel" Grid.Column="1" Opacity="0.7"
                                           VerticalAlignment="Center" FontSize="12" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- سه پردازه‌ی پرمصرف مربوط به این گراف -->
                    <Border x:Name="TopCard" Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE9D5;" FontSize="14" Opacity="0.7" />
                                <TextBlock x:Name="TopTitle" Text="Top processes" Opacity="0.7" />
                            </StackPanel>
                            <StackPanel x:Name="TopPanel" Spacing="4" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="SecondCard" Style="{StaticResource CardBorderStyle}" Visibility="Collapsed">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="SecondGraphLabel" Opacity="0.7" />
                            <controls:LiveGraph x:Name="SecondGraph" Height="140" />
                        </StackPanel>
                    </Border>

                    <!-- آمار عددی (مثل بخش پایین Performance در Task Manager) -->
                    <!-- GPU engine graphs (3D / Copy / Video Decode / Video Processing) -->
                    <Border x:Name="EnginesCard" Style="{StaticResource CardBorderStyle}" Visibility="Collapsed">
                        <Grid ColumnSpacing="16" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Spacing="8">
                                <TextBlock x:Name="Eng0Label" Text="3D" Opacity="0.7" />
                                <controls:LiveGraph x:Name="Eng0Graph" Height="90" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock x:Name="Eng1Label" Text="Copy" Opacity="0.7" />
                                <controls:LiveGraph x:Name="Eng1Graph" Height="90" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Spacing="8">
                                <TextBlock x:Name="Eng2Label" Text="Video Decode" Opacity="0.7" />
                                <controls:LiveGraph x:Name="Eng2Graph" Height="90" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="8">
                                <TextBlock x:Name="Eng3Label" Text="Video Processing" Opacity="0.7" />
                                <controls:LiveGraph x:Name="Eng3Graph" Height="90" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- سنسورهای کامل سخت‌افزار (LibreHardwareMonitor) -->
                    <Border x:Name="SensorsCard" Style="{StaticResource CardBorderStyle}" Visibility="Collapsed">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="SensorsHint" Opacity="0.6" FontSize="12" TextWrapping="Wrap"
                                       Text="Full sensor data (fans, voltages, power) may need Run as administrator." />
                            <StackPanel x:Name="SensorsPanel" Spacing="10" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="StatsCard" Style="{StaticResource CardBorderStyle}">
                        <VariableSizedWrapGrid x:Name="StatsPanel"
                                               Orientation="Horizontal"
                                               ItemWidth="180"
                                               ItemHeight="64" />
                    </Border>

                    <Border x:Name="CoresCard" Style="{StaticResource CardBorderStyle}" Visibility="Collapsed">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE950;" FontSize="14" Opacity="0.7" />
                                <TextBlock x:Name="LogicalProcLabel" Text="Logical processors" Opacity="0.7" />
                            </StackPanel>
                            <VariableSizedWrapGrid x:Name="CoresPanel"
                                                   Orientation="Horizontal"
                                                   ItemWidth="150"
                                                   ItemHeight="46" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
