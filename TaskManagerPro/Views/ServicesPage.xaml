<Page
    x:Class="TaskManagerPro.Views.ServicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:TaskManagerPro.Models">

    <!-- هات‌کی‌های این صفحه -->
    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="FindAccel_Invoked" />
        <KeyboardAccelerator Key="F5" Invoked="RefreshAccel_Invoked" />
    </Page.KeyboardAccelerators>

    <Grid Padding="24,16,24,24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <FontIcon Glyph="&#xE912;" FontSize="24"
                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            <TextBlock Text="Services" Style="{StaticResource TitleTextBlockStyle}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="SearchBox"
                     PlaceholderText="Search services...  (Ctrl+F)"
                     Width="260"
                     TextChanged="SearchBox_TextChanged" />
            <Button Click="Refresh_Click" ToolTipService.ToolTip="Refresh (F5)">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="Refresh" />
                </StackPanel>
            </Button>
        </StackPanel>

        <InfoBar x:Name="ErrorBar"
                 Grid.Row="2"
                 Title="Note"
                 Severity="Warning"
                 IsOpen="False"
                 IsClosable="True" />

        <ListView x:Name="ServicesList" Grid.Row="3" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ServiceRow">
                    <Grid ColumnSpacing="12" Padding="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Bind Status}"
                                   VerticalAlignment="Center"
                                   Opacity="0.8" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind DisplayName}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind Name}" Opacity="0.6" FontSize="12" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                            <Button Click="Start_Click" ToolTipService.ToolTip="Start">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE768;" FontSize="13" />
                                    <TextBlock Text="Start" />
                                </StackPanel>
                            </Button>
                            <Button Click="Stop_Click" ToolTipService.ToolTip="Stop">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE71A;" FontSize="13" />
                                    <TextBlock Text="Stop" />
                                </StackPanel>
                            </Button>
                            <Button Click="Restart_Click" ToolTipService.ToolTip="Restart">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE72C;" FontSize="13" />
                                    <TextBlock Text="Restart" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
